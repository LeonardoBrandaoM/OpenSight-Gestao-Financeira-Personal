# account-service (dev local). Copie para .env e ajuste. NÃO commitar o .env.
# Sem DATABASE_URL, o serviço usa o repositório em memória (dados de exemplo).
PORT=8081
# Postgres (exige o driver pgx registrado no main + migrations aplicadas):
# DATABASE_URL=postgres://account_app:senha@localhost:5432/account_db?sslmode=require
# Origens do navegador permitidas (CORS allowlist), separadas por vírgula:
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Autenticação: com a chave PÚBLICA do auth-service, o JWT passa a ser obrigatório.
# Sem ela = modo dev (X-User-ID / usuário-semente). Obtenha em GET :8082/api/v1/auth/public-key.
# AUTH_PUBLIC_KEY_FILE=./auth_public.pem
JWT_ISSUER=opensight-auth
