# auth-service (dev local). Copie para .env. NÃO commitar o .env.
PORT=8082
# Sem DATABASE_URL usa repositório em memória (dev).
# DATABASE_URL=postgres://auth_app:senha@localhost:5432/auth_db?sslmode=require
JWT_ISSUER=opensight-auth
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Chave RSA para assinar os JWT (RS256). Sem ela, gera uma efêmera (só dev).
# Gere com: openssl genrsa -out jwt_private.pem 2048
# JWT_PRIVATE_KEY_FILE=./jwt_private.pem
# A chave PÚBLICA correspondente vai no account-service (AUTH_PUBLIC_KEY) ou é
# obtida em GET /api/v1/auth/public-key.
