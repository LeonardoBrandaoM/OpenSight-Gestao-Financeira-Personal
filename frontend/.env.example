# Frontend (Vite). Copie para .env.local (gitignored). Só variáveis VITE_* são
# expostas ao navegador — NUNCA coloque segredos aqui.
# Bases por serviço (cada microsserviço numa porta). Defaults entre parênteses.
VITE_ACCOUNTS_URL=http://localhost:8081
VITE_AUTH_URL=http://localhost:8082
VITE_TRANSACTIONS_URL=http://localhost:8083
VITE_ANALYTICS_URL=http://localhost:8084
VITE_BUDGET_URL=http://localhost:8085
VITE_PROJECTION_URL=http://localhost:8086
VITE_CONSENT_URL=http://localhost:8087
VITE_COHORT_URL=http://localhost:8088
# Fallback p/ accounts (compatibilidade):
VITE_API_URL=http://localhost:8081
